{
  "description": "beams plugin: proactive delivery of cross-terminal messages — pull-on-prompt (UserPromptSubmit), surface-on-boot (SessionStart), and opt-in active-session sustain (Stop)",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-messages.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-on-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/respond-on-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
